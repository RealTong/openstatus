# ============================================================================
# Docker Environment Configuration (Example)
# ============================================================================
# Copy this file to .env.docker and replace with your actual values
# Required values are marked with [REQUIRED]

# DATABASE
# ============================================================================
# LibSQL database connection - points to the libsql container
DATABASE_URL=http://libsql:8080
DATABASE_AUTH_TOKEN=

# EMAIL
# ============================================================================
# Resend API key for sending notification emails
# Get from: https://resend.com
RESEND_API_KEY=re_your_resend_api_key_here

# AUTHENTICATION
# ============================================================================
# [REQUIRED] NextAuth secret - generate with: openssl rand -base64 32
AUTH_SECRET=your-random-secret-here-min-32-chars

# [REQUIRED] Self-hosted mode
SELF_HOST="true"

# GitHub OAuth (optional)
# Get from: https://github.com/settings/developers
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Google OAuth (optional)
# Get from: https://console.cloud.google.com
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Custom OIDC Provider (optional - e.g. PocketID, Authentik, Keycloak)
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_DISPLAY_NAME=

# INTERNAL
# ============================================================================
# Cron secret for checker-server communication
CRON_SECRET=your-random-cron-secret

# Super admin token for privileged API operations
SUPER_ADMIN_TOKEN=

# SERVICE CONFIGURATION
# ============================================================================
NODE_ENV=production

# [REQUIRED] Public URL for the dashboard
NEXT_PUBLIC_URL=http://localhost:3002

# Screenshot service (optional)
SCREENSHOT_SERVICE_URL=

# DATA RETENTION
# ============================================================================
# Number of days to keep monitoring data (default: 90)
DATA_RETENTION_DAYS=90
