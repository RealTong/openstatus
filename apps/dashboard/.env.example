# RESEND for email
RESEND_API_KEY=resend-api-key

# TURSO SQLITE
DATABASE_URL=http://127.0.0.1:8080
DATABASE_AUTH_TOKEN=any-token

# Solves 'UNABLE_TO_GET_ISSUER_CERT_LOCALLY', see https://github.com/nextauthjs/next-auth/issues/3580
# NODE_TLS_REJECT_UNAUTHORIZED="0"

NEXT_PUBLIC_URL=

CRON_SECRET=

AUTH_SECRET=secret
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Optional: OIDC SSO provider (e.g. Keycloak, Authentik, Okta)
# OIDC_ISSUER=https://your-oidc-provider.example.com/realms/your-realm
# OIDC_CLIENT_ID=openstatus
# OIDC_CLIENT_SECRET=your-client-secret
# OIDC_DISPLAY_NAME=SSO

# https://turbo.build/repo/docs/crafting-your-repository/using-environment-variables#loose-mode
TURBO_ENV_MODE=loose
