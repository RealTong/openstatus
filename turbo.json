{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "\\*",
        "RESEND_API_KEY",
        "\\!NEXT_PUBLIC_GIT_\\*",
        "DATABASE_URL",
        "DATABASE_AUTH_TOKEN",
        "NODE_ENV",
        "AUTH_SECRET",
        "CRON_SECRET",
        "SELF_HOST"
      ],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {},
    "dev": {
      "cache": false
    },
    "@openstatus/status-page#dev": {
      "cache": false
    },
    "@openstatus/dashboard#dev": {
      "cache": false
    },
    "test": {
      "cache": false
    },
    "dx": {
      "cache": false,
      "dependsOn": ["seed"]
    },
    "seed": {
      "cache": false,
      "dependsOn": ["migrate"]
    },
    "migrate": {
      "cache": false,
      "dependsOn": ["env"]
    },
    "env": {
      "cache": true
    }
  }
}
