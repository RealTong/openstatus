# ============================================================================
# Docker Environment Configuration - Lightweight (Example)
# ============================================================================
# Simplified config for basic self-hosted deployment
# Copy this file to .env.docker and replace with your actual values

# DATABASE
# ============================================================================
DATABASE_URL=http://libsql:8080
DATABASE_AUTH_TOKEN=

# EMAIL
# ============================================================================
RESEND_API_KEY=re_your_resend_api_key_here

# AUTHENTICATION
# ============================================================================
AUTH_SECRET=your-random-secret-here-min-32-chars
SELF_HOST="true"

# GitHub OAuth (optional)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Google OAuth (optional)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Custom OIDC Provider (optional)
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_DISPLAY_NAME=

# INTERNAL
# ============================================================================
SUPER_ADMIN_TOKEN=
CRON_SECRET=your-random-cron-secret

# SERVICE CONFIGURATION
# ============================================================================
NODE_ENV=production
NEXT_PUBLIC_URL=http://localhost:3002
